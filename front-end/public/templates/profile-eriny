<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile | PAD - Eriny Mouner</title>
    
    <!-- ربط خطوط جوجل الاحترافية -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;700;800&family=Nunito:wght@400;600;800;900&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        /* =======================================
           التنسيقات الأساسية
           ======================================= */
        body { 
            background-color: #070b17; 
            color: #eaf0ff; 
            font-family: 'Nunito', sans-serif;
            background-image: radial-gradient(circle at top right, rgba(27, 116, 228, 0.05), transparent 50%),
                              radial-gradient(circle at bottom left, rgba(162, 139, 255, 0.05), transparent 50%);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .code-font { font-family: 'JetBrains Mono', monospace; }

        .btn-floating-back {
            position: fixed; top: 20px; left: 20px; z-index: 1000;
            background: rgba(15, 25, 51, 0.8); border: 1px solid rgba(145, 175, 255, 0.15);
            color: #a3b8cc; padding: 10px 20px; border-radius: 50px;
            font-weight: 800; font-size: 14px; text-decoration: none;
            display: inline-flex; align-items: center; gap: 10px;
            backdrop-filter: blur(10px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); transition: all 0.3s ease;
        }
        .btn-floating-back:hover { background: #1b74e4; color: #fff; transform: translateX(-5px); border-color: #1b74e4; }

        .profile-container { max-width: 1000px; margin: 60px auto 40px; padding: 20px; }

        /* الهيدر */
        .profile-header-card {
            background: linear-gradient(145deg, rgba(15, 25, 51, 0.8), rgba(12, 19, 39, 0.9));
            border: 1px solid rgba(145, 175, 255, 0.1); border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4); position: relative; overflow: hidden; backdrop-filter: blur(10px);
        }
        
        .profile-cover {
            height: 220px; background: url('https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=1200&q=80') center/cover;
            position: relative;
        }
        .profile-cover::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, transparent, rgba(12, 19, 39, 1)); }

        .profile-img-wrap { margin-top: -80px; position: relative; z-index: 2; display: inline-block; }
        .profile-img { width: 160px; height: 160px; border-radius: 50%; border: 5px solid #0f1933; box-shadow: 0 0 30px rgba(236, 72, 153, 0.6); object-fit: cover; background-color: #fff; transition: filter 0.3s; }
        
        .edit-img-btn { position: absolute; bottom: 10px; right: 5px; width: 45px; height: 45px; border-radius: 50%; background: #ec4899; color: white; border: 4px solid #0f1933; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.3s; box-shadow: 0 5px 15px rgba(0,0,0,0.4); }
        .edit-img-btn:hover { background: #f472b6; color: #000; transform: scale(1.1); }
        #img-upload-input { display: none; }

        .user-name { font-size: 34px; font-weight: 900; letter-spacing: -0.5px; margin-bottom: 5px; color: #fff;}
        .user-bio { font-size: 16px; font-weight: 600; color: #fbcfe8; margin-bottom: 15px; letter-spacing: 0.5px;}
        
        .social-links a { color: #f9a8d4; font-size: 22px; margin: 0 10px; transition: 0.3s; text-decoration: none;}
        .social-links a:hover { color: #ec4899; transform: translateY(-3px); display: inline-block; text-shadow: 0 0 10px rgba(236,72,153,0.5);}

        .level-badge { background: rgba(236, 72, 153, 0.15); border: 1px solid rgba(236, 72, 153, 0.3); color: #fbcfe8; padding: 6px 18px; border-radius: 50px; font-weight: 800; font-size: 12px; letter-spacing: 1px; text-transform: uppercase;}

        /* كروت الإحصائيات مع تحسين ألوان العناوين */
        .stat-card { background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 20px; transition: all 0.3s ease; height: 100%; padding: 25px !important;}
        .stat-card:hover { transform: translateY(-5px); background: rgba(255, 255, 255, 0.06); border-color: rgba(236, 72, 153, 0.3); box-shadow: 0 10px 20px rgba(0,0,0,0.2);}
        .icon-box { width: 60px; height: 60px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 26px; margin: 0 auto 15px; }
        
        .bg-blue-glow { background: rgba(27, 116, 228, 0.15); color: #6ce5ff; box-shadow: 0 0 20px rgba(27, 116, 228, 0.25);}
        .bg-purple-glow { background: rgba(162, 139, 255, 0.15); color: #c4b5fd; box-shadow: 0 0 20px rgba(162, 139, 255, 0.25);}
        .bg-pink-glow { background: rgba(236, 72, 153, 0.15); color: #fbcfe8; box-shadow: 0 0 20px rgba(236, 72, 153, 0.25);}
        .bg-green-glow { background: rgba(34, 197, 94, 0.15); color: #6ee7b7; box-shadow: 0 0 20px rgba(34, 197, 94, 0.25);}

        /* اللون الجديد الواضح للعناوين تحت الأرقام */
        .stat-label { 
            color: #fbcfe8; 
            font-size: 13px; 
            letter-spacing: 1.5px; 
            text-transform: uppercase; 
            font-weight: 800; 
            display: block; 
            margin-top: 5px;
        }

        /* الكروت العامة */
        .detail-card { background: rgba(15, 25, 51, 0.4); border: 1px solid rgba(145, 175, 255, 0.08); border-radius: 24px; padding: 25px; height: 100%; box-shadow: 0 10px 30px rgba(0,0,0,0.15);}
        .detail-card h5 { color: #fff; font-size: 18px; font-weight: 800; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 15px;}
        
        /* قسم المشاريع */
        .project-card {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 15px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s ease;
        }
        .project-card:hover {
            border-color: rgba(236, 72, 153, 0.3);
            background: rgba(236, 72, 153, 0.05);
            transform: translateX(5px);
        }
        .project-info h6 {
            color: #fff;
            font-weight: 800;
            margin-bottom: 5px;
        }
        .project-info p {
            color: #fbcfe8;
            font-size: 13px;
            margin: 0;
        }
        .delete-project-btn {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #ef4444;
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .delete-project-btn:hover {
            background: #ef4444;
            color: #fff;
            transform: scale(1.1);
            border-color: #ef4444;
        }
        
        /* نافذة تأكيد الحذف المخصصة */
        .delete-modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 99999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }
        .delete-modal.show {
            opacity: 1;
            visibility: visible;
        }
        .delete-modal-content {
            background: linear-gradient(145deg, rgba(15, 25, 51, 0.95), rgba(12, 19, 39, 0.98));
            border: 1px solid rgba(236, 72, 153, 0.3);
            border-radius: 24px;
            padding: 30px;
            max-width: 400px;
            width: 90%;
            text-align: center;
            transform: scale(0.9);
            transition: all 0.3s ease;
            box-shadow: 0 20px 40px rgba(236, 72, 153, 0.2);
        }
        .delete-modal.show .delete-modal-content {
            transform: scale(1);
        }
        .delete-modal-icon {
            width: 70px;
            height: 70px;
            background: rgba(239, 68, 68, 0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 30px;
            color: #ef4444;
            border: 2px solid rgba(239, 68, 68, 0.3);
        }
        .delete-modal h3 {
            color: #fff;
            font-weight: 800;
            margin-bottom: 10px;
        }
        .delete-modal p {
            color: #fbcfe8;
            margin-bottom: 25px;
            font-size: 14px;
        }
        .delete-modal-buttons {
            display: flex;
            gap: 10px;
        }
        .delete-modal-buttons button {
            flex: 1;
            padding: 12px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 14px;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .btn-cancel {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .btn-cancel:hover {
            background: rgba(255, 255, 255, 0.2);
        }
        .btn-confirm-delete {
            background: #ef4444;
            color: #fff;
        }
        .btn-confirm-delete:hover {
            background: #dc2626;
            transform: scale(1.05);
        }

        /* قسم Contribution Graph */
        .contribution-graph { display: flex; gap: 4px; flex-wrap: wrap; justify-content: flex-start; margin-top: 15px;}
        .contrib-box { width: 14px; height: 14px; border-radius: 3px; background: rgba(255,255,255,0.05); transition: 0.2s; cursor: pointer;}
        .contrib-box:hover { transform: scale(1.2); border: 1px solid #fff;}
        .lvl-1 { background: #831843; }
        .lvl-2 { background: #9d174d; }
        .lvl-3 { background: #be185d; }
        .lvl-4 { background: #db2777; }

        .skill-tag { background: rgba(236, 72, 153, 0.1); border: 1px solid rgba(236, 72, 153, 0.2); color: #fbcfe8; font-weight: 800; font-size: 13px; letter-spacing: 0.5px;}

        .book-card { background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 15px; display: flex; align-items: center; gap: 15px; transition: all 0.3s; }
        .book-card:hover { border-color: #ec4899; transform: scale(1.02); background: rgba(236, 72, 153, 0.05); box-shadow: 0 5px 15px rgba(236,72,153,0.1);}
        .book-icon { font-size: 30px; color: #ec4899; }
        .book-info h6 { margin: 0 0 5px 0; color: #fff; font-size: 16px; font-weight: 800;}
        .book-info p { margin: 0; color: #fbcfe8; font-size: 13px; font-weight: 600;}

        .toast-container { position: fixed; bottom: 20px; right: 20px; z-index: 9999; }
    </style>
</head>
<body>

<!-- زر الرجوع العائم المربوط بـ Flask -->
<a href="{{ url_for('home_page') }}" class="btn-floating-back">
    <i class="fa-solid fa-arrow-left"></i>
    <span>Back to PAD</span>
</a>

{% set is_owner = (session.user_id == user.id) %}

<div class="profile-container">
    
    <!-- 1. الهيدر الشخصي -->
    <div class="profile-header-card text-center mb-5">
        <div class="profile-cover"></div>
        
        <div class="profile-img-wrap">
            <img src="{{ url_for('static', filename='images/' + user.profile_image) }}" alt="Eriny Mouner" class="profile-img" id="user-avatar" onerror="this.src='https://ui-avatars.com/api/?name=Eriny+Mouner&size=160&length=2&background=ec4899&color=fff&bold=true'">
            {% if is_owner %}
            <label for="img-upload-input" class="edit-img-btn" title="Change Profile Picture">
                <i class="fa-solid fa-camera"></i>
            </label>
            <input type="file" id="img-upload-input" accept="image/png, image/jpeg, image/jpg">
            {% endif %}
        </div>
        
        <div class="p-4 pt-2">
            <h2 class="user-name">{{ user.username }}</h2>
            <p class="user-bio"><i class="fa-solid fa-code text-pink me-2"></i>{{ user.bio or 'UI/UX Designer & Frontend Developer' }}</p>
            
            <div class="social-links mb-4">
                <a href="#" title="GitHub"><i class="fa-brands fa-github"></i></a>
                <a href="#" title="LinkedIn"><i class="fa-brands fa-linkedin"></i></a>
                <a href="#" title="Behance"><i class="fa-brands fa-behance"></i></a>
                <a href="#" title="Dribbble"><i class="fa-brands fa-dribbble"></i></a>
            </div>

            <span class="level-badge mb-4"><i class="fa-solid fa-crown text-warning me-1"></i> {{ user.programming_level or 'Pad Designer' }}</span>
            
            <div class="d-flex justify-content-center gap-3 mt-3">
                <button class="btn btn-outline-light px-4 py-2 rounded-pill fw-bold border-secondary" onclick="copyProfileLink()">
                    <i class="fa-solid fa-share-nodes me-2"></i> Share Profile
                </button>
                {% if is_owner %}
                <button class="btn btn-primary px-4 py-2 rounded-pill shadow-sm fw-bold" style="background: #ec4899; border:none;" onclick="editProfile()">
                    <i class="fa-solid fa-pen-to-square me-2"></i> Edit Details
                </button>
                {% else %}
                <button class="btn btn-primary px-4 py-2 rounded-pill shadow-sm fw-bold" style="background: #ec4899; border:none;" onclick="followUser()" id="followBtn">
                    <i class="fa-solid fa-user-plus me-2"></i> Follow
                </button>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- 2. شبكة الإحصائيات (Count Up Animation + توضيح الألوان) -->
    <div class="row g-4 mb-5 text-center">
        <div class="col-6 col-md-4">
            <div class="stat-card">
                <div class="icon-box bg-blue-glow"><i class="fa-solid fa-folder-open"></i></div>
                <h2 class="text-white fw-bold mb-0 code-font" style="font-size: 36px;" id="projects-count">{{ projects|length }}</h2>
                <span class="stat-label">Projects</span> 
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="stat-card">
                <div class="icon-box bg-purple-glow"><i class="fa-solid fa-users"></i></div>
                <h2 class="text-white fw-bold mb-0 code-font" style="font-size: 36px;" id="followers-count">{{ followers_count|default(0) }}</h2>
                <span class="stat-label">Followers</span>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="stat-card">
                <div class="icon-box bg-pink-glow"><i class="fa-solid fa-heart"></i></div>
                <h2 class="text-white fw-bold mb-0 code-font" style="font-size: 36px;" id="likes-count">0</h2>
                <span class="stat-label">Likes</span>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="stat-card">
                <div class="icon-box bg-green-glow"><i class="fa-solid fa-paint-brush"></i></div>
                <h2 class="text-white fw-bold mb-0 code-font" style="font-size: 36px;" id="designs-count">0</h2>
                <span class="stat-label">Designs</span>
            </div>
        </div>
    </div>

    <!-- 3. قسم النشاط الأسبوعي -->
    <div class="detail-card mb-5">
        <h5><i class="fa-solid fa-calendar-check text-pink me-2"></i> Design Activity (Last 30 Days)</h5>
        <div class="contribution-graph" id="contrib-graph">
            <!-- بيتم توليد المربعات بالجافاسكريبت تحت -->
        </div>
        <div class="d-flex justify-content-end align-items-center mt-3 gap-2" style="font-size: 12px; color: #fbcfe8;">
            <span>Less</span>
            <div class="contrib-box"></div>
            <div class="contrib-box lvl-1"></div>
            <div class="contrib-box lvl-2"></div>
            <div class="contrib-box lvl-3"></div>
            <div class="contrib-box lvl-4"></div>
            <span>More</span>
        </div>
    </div>

    <!-- 4. قسم المشاريع مع خاصية الحذف -->
    <div class="detail-card mb-5">
        <h5><i class="fa-solid fa-palette text-pink me-2"></i> My Design Projects</h5>
        <div class="projects-list" id="projects-list">
            {% if projects %}
                {% for project in projects %}
                <div class="project-card" data-project-id="{{ project.id }}">
                    <div class="project-info">
                        <h6>{{ project.title }}</h6>
                        <p>{{ project.description }}</p>
                    </div>
                    {% if is_owner %}
                    <div class="delete-project-btn" onclick="deleteProject({{ project.id }})">
                        <i class="fa-solid fa-trash-can"></i>
                    </div>
                    {% endif %}
                </div>
                {% endfor %}
            {% else %}
                <p class="text-muted text-center">No projects yet</p>
            {% endif %}
        </div>
        {% if is_owner %}
        <button class="btn btn-outline-pink w-100 mt-3 py-2 rounded-pill fw-bold" style="border-color: #ec4899; color: #ec4899;" onclick="addNewProject()">
            <i class="fa-solid fa-plus me-2"></i> Add New Project
        </button>
        {% endif %}
    </div>

    <!-- 5. قسم الدورات التعليمية -->
    <div class="detail-card mb-5">
        <h5><i class="fa-solid fa-graduation-cap text-warning me-2"></i> Completed Courses</h5>
        <p style="color: #fbcfe8; font-size: 13px; margin-top: -15px; margin-bottom: 20px;">
            Professional design courses completed on PAD platform.
        </p>
        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <div class="book-card" style="cursor: pointer;" title="View Certificate">
                    <i class="fa-solid fa-certificate book-icon" style="color: #ec4899;"></i>
                    <div class="book-info">
                        <h6>UI/UX Masterclass</h6>
                        <p>Completed 2024</p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="book-card" style="cursor: pointer;" title="View Certificate">
                    <i class="fa-solid fa-certificate book-icon" style="color: #ec4899;"></i>
                    <div class="book-info">
                        <h6>Advanced Figma</h6>
                        <p>Completed 2024</p>
                    </div>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="book-card" style="cursor: pointer;" title="View Certificate">
                    <i class="fa-solid fa-certificate book-icon" style="color: #ec4899;"></i>
                    <div class="book-info">
                        <h6>Design Systems</h6>
                        <p>Completed 2023</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 6. قسم المهارات والجوائز -->
    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="detail-card">
                <h5><i class="fa-solid fa-laptop-code text-info me-2"></i> Tech Stack & Tools</h5>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <span class="badge skill-tag py-2 px-3">Figma</span>
                    <span class="badge skill-tag py-2 px-3">Adobe XD</span>
                    <span class="badge skill-tag py-2 px-3">Photoshop</span>
                    <span class="badge skill-tag py-2 px-3">Illustrator</span>
                    <span class="badge skill-tag py-2 px-3">React</span>
                    <span class="badge skill-tag py-2 px-3">Tailwind CSS</span>
                    <span class="badge skill-tag py-2 px-3">Framer</span>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="detail-card">
                <h5><i class="fa-solid fa-trophy text-warning me-2"></i> Achievements</h5>
                <div class="d-flex justify-content-between align-items-center mb-3 bg-dark bg-opacity-50 p-3 rounded">
                    <span class="stat-label m-0" style="font-size: 14px;"><i class="fa-solid fa-medal me-2" style="color: #ec4899;"></i> Design Awards</span>
                    <span class="fs-5 fw-bold text-white code-font">8 <i class="fa-solid fa-star text-warning fs-6 ms-1"></i></span>
                </div>
                <div class="d-flex justify-content-between align-items-center bg-dark bg-opacity-50 p-3 rounded">
                    <span class="stat-label m-0" style="font-size: 14px;"><i class="fa-solid fa-users me-2" style="color: #ec4899;"></i> Workshop Hosted</span>
                    <span class="fs-5 fw-bold text-white code-font">12 <i class="fa-solid fa-video text-success fs-6 ms-1"></i></span>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- نافذة تأكيد الحذف المخصصة -->
<div class="delete-modal" id="deleteModal">
    <div class="delete-modal-content">
        <div class="delete-modal-icon">
            <i class="fa-solid fa-exclamation-triangle"></i>
        </div>
        <h3>Delete Project</h3>
        <p id="delete-project-name">Are you sure you want to delete this project? This action cannot be undone.</p>
        <div class="delete-modal-buttons">
            <button class="btn-cancel" onclick="closeDeleteModal()">Cancel</button>
            <button class="btn-confirm-delete" onclick="confirmDelete()">Delete</button>
        </div>
    </div>
</div>

<div class="toast-container"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // متغيرات عامة
    let currentDeleteProjectId = null;
    let isOwner = {% if is_owner %}true{% else %}false{% endif %};

    // 1. توليد مربعات النشاط
    const graphContainer = document.getElementById('contrib-graph');
    for (let i = 0; i < 90; i++) {
        const box = document.createElement('div');
        box.className = 'contrib-box';
        const rand = Math.random();
        if(rand > 0.85) box.classList.add('lvl-4');
        else if(rand > 0.65) box.classList.add('lvl-3');
        else if(rand > 0.4) box.classList.add('lvl-2');
        else if(rand > 0.2) box.classList.add('lvl-1');
        graphContainer.appendChild(box);
    }

    // 2. تغيير الصورة (للمالك فقط)
    {% if is_owner %}
    const imageInput = document.getElementById('img-upload-input');
    const avatarImg = document.getElementById('user-avatar');

    imageInput.addEventListener('change', function(event) {
        const file = event.target.files[0];
        if (!file) return;
        
        const formData = new FormData();
        formData.append('avatar', file);
        
        fetch('/api/upload-avatar', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            if(data.success) {
                avatarImg.src = '/static/images/' + data.filename + '?t=' + new Date().getTime();
                showToast('Profile picture updated!', 'success');
            } else {
                showToast('Error uploading image', 'danger');
            }
        })
        .catch(error => {
            showToast('Error uploading image', 'danger');
        });
    });
    {% endif %}

    // 3. نسخ الرابط
    function copyProfileLink() {
        const dummy = document.createElement('input');
        document.body.appendChild(dummy);
        dummy.value = window.location.href;
        dummy.select();
        document.execCommand('copy');
        document.body.removeChild(dummy);
        showToast('Profile link copied to clipboard!', 'primary');
    }

    // 4. إضافة مشروع جديد
    function addNewProject() {
        const projectName = prompt('Enter project name:');
        if (!projectName) return;
        
        const projectDesc = prompt('Enter project description:');
        if (!projectDesc) return;
        
        fetch('/api/add-project', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                name: projectName,
                description: projectDesc
            })
        })
        .then(response => response.json())
        .then(data => {
            if(data.success) {
                // إضافة المشروع للصفحة
                const projectsList = document.getElementById('projects-list');
                
                // إخفاء رسالة "No projects yet" لو موجودة
                if (projectsList.children.length === 1 && projectsList.children[0].tagName === 'P') {
                    projectsList.innerHTML = '';
                }
                
                const newProject = document.createElement('div');
                newProject.className = 'project-card';
                newProject.setAttribute('data-project-id', data.project.id);
                newProject.innerHTML = `
                    <div class="project-info">
                        <h6>${data.project.name}</h6>
                        <p>${data.project.description}</p>
                    </div>
                    <div class="delete-project-btn" onclick="deleteProject(${data.project.id})">
                        <i class="fa-solid fa-trash-can"></i>
                    </div>
                `;
                
                projectsList.appendChild(newProject);
                
                // تحديث العداد
                document.getElementById('projects-count').textContent = projectsList.children.length;
                
                showToast('Project added successfully!', 'success');
            }
        });
    }

    // 5. حذف مشروع
    function deleteProject(projectId) {
        currentDeleteProjectId = projectId;
        const projectCard = document.querySelector(`.project-card[data-project-id="${projectId}"]`);
        const projectName = projectCard.querySelector('h6').textContent;
        
        document.getElementById('delete-project-name').textContent = 
            'Are you sure you want to delete "' + projectName + '"? This action cannot be undone.';
        document.getElementById('deleteModal').classList.add('show');
    }

    function closeDeleteModal() {
        document.getElementById('deleteModal').classList.remove('show');
        currentDeleteProjectId = null;
    }

    function confirmDelete() {
        if (!currentDeleteProjectId) return;
        
        fetch('/api/delete-project/' + currentDeleteProjectId, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if(data.success) {
                // حذف المشروع من الصفحة
                const projectCard = document.querySelector(`.project-card[data-project-id="${currentDeleteProjectId}"]`);
                projectCard.remove();
                
                // تحديث العداد
                const projectsList = document.getElementById('projects-list');
                document.getElementById('projects-count').textContent = projectsList.children.length;
                
                // لو مفيش مشاريع، نضيف رسالة
                if (projectsList.children.length === 0) {
                    projectsList.innerHTML = '<p class="text-muted text-center">No projects yet</p>';
                }
                
                showToast('Project deleted successfully!', 'success');
            }
        })
        .finally(() => {
            closeDeleteModal();
        });
    }

    // 6. متابعة مستخدم
    function followUser() {
        fetch('/api/follow/{{ user.id }}', {
            method: 'POST'
        })
        .then(response => response.json())
        .then(data => {
            if(data.success) {
                const followBtn = document.getElementById('followBtn');
                followBtn.innerHTML = '<i class="fa-solid fa-user-check me-2"></i> Following';
                followBtn.style.background = '#22c55e';
                
                document.getElementById('followers-count').innerText = data.followers_count;
                
                showToast('You are now following this user!', 'success');
            }
        })
        .catch(error => {
            showToast('Error following user', 'danger');
        });
    }

    // 7. تعديل البروفايل
    function editProfile() {
        showToast('Edit feature coming soon!', 'info');
    }

    // 8. دوال الإشعارات
    function showToast(message, type) {
        let icon = 'fa-info-circle';
        let bgColor = '#3b82f6';
        
        if (type === 'success') {
            icon = 'fa-check-circle';
            bgColor = '#22c55e';
        } else if (type === 'danger') {
            icon = 'fa-exclamation-circle';
            bgColor = '#ef4444';
        } else if (type === 'primary') {
            icon = 'fa-info-circle';
            bgColor = '#3b82f6';
        }
        
        const toastHTML = `
            <div class="toast align-items-center border-0 show mb-2 shadow-lg" role="alert" style="background: ${bgColor}; color: white;">
              <div class="d-flex">
                <div class="toast-body fw-bold" style="font-family: 'Nunito', sans-serif;">
                  <i class="fa-solid ${icon} me-2"></i> ${message}
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
              </div>
            </div>`;
        const container = document.querySelector('.toast-container');
        container.innerHTML += toastHTML;
        setTimeout(() => { 
            if(container.firstChild) container.removeChild(container.firstChild); 
        }, 3000);
    }

    // إغلاق النافذة عند الضغط على ESC
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && document.getElementById('deleteModal').classList.contains('show')) {
            closeDeleteModal();
        }
    });
</script>
